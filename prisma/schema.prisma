// Use Postgres for deployed environments.
//
// On Vercel (serverless), every concurrent function instance opens its own DB
// connection, so DATABASE_URL MUST be a POOLED connection string (Neon pooler,
// Supabase port 6543 / pgbouncer, or Prisma Accelerate) to avoid exhausting
// Postgres connection limits under load.
//
// Transaction-mode poolers do not support the statements `prisma migrate`
// needs, so DIRECT_URL points at the UNPOOLED (direct) connection used only for
// migrations and introspection. See .env.example and docs/vercel-cache-strategy.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String            @unique
  emailVerified DateTime?
  image         String?
  password      String? // null for OAuth-only users
  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  history       ReadingProgress[]
  readingSessions ReadingSession[]
  shelves       Shelf[]
  createdAt     DateTime          @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  mangaId   String
  title     String
  coverUrl  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
}

model ReadingProgress {
  id        String   @id @default(cuid())
  userId    String
  mangaId   String
  chapterId String
  title     String
  coverUrl  String?
  chapter   String?
  page      Int?
  totalPages Int?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
}

model Shelf {
  id        String      @id @default(cuid())
  userId    String
  name      String
  colorVibe String      @default("indigo")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ShelfItem[]

  @@unique([userId, name])
  @@index([userId, updatedAt])
}

model ShelfItem {
  id        String   @id @default(cuid())
  shelfId   String
  mangaId   String
  title     String
  coverUrl  String?
  createdAt DateTime @default(now())
  shelf     Shelf    @relation(fields: [shelfId], references: [id], onDelete: Cascade)

  @@unique([shelfId, mangaId])
}

model ReadingSession {
  id              String   @id @default(cuid())
  userId          String
  mangaId         String
  mangaTitle      String
  chapterId       String
  pagesRead       Int
  durationSeconds Int
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, mangaId])
}
