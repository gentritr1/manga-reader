# Postgres connection (serverless on Vercel).
# DATABASE_URL MUST be a POOLED connection string or you will exhaust DB
# connections under load. Use the Neon pooler host, Supabase port 6543
# (pgbouncer / transaction mode), or a Prisma Accelerate URL.
#   Neon:     postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
#   Supabase: postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
# DIRECT_URL is the UNPOOLED (direct) connection used only by `prisma migrate`
# and introspection, since transaction-mode poolers break migrations. Point it
# at the non-pooler host / Supabase port 5432.
#   Neon:     postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DB?sslmode=require
#   Supabase: postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
AUTH_SECRET=""
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DIRECT_COVERS="false"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

NEXT_PUBLIC_SUPPORT_URL=""

# Adsterra ads. ADSTERRA_SCRIPT_URL is server-only and is only returned to the
# first two created user accounts. Anonymous users and later accounts see no ads.
ADSTERRA_SCRIPT_URL=""
# NEXT_PUBLIC_* keys are inlined into the client bundle and used to build each
# ad slot's config directly (no per-slot fetch).
NEXT_PUBLIC_ADS_ENABLED="false"
NEXT_PUBLIC_ADSTERRA_BANNER_KEY=""
NEXT_PUBLIC_ADSTERRA_CHAPTER_END_KEY=""
NEXT_PUBLIC_ADSTERRA_CHAPTER_START_SRC=""
NEXT_PUBLIC_ADSTERRA_CHAPTER_START_CONTAINER=""
NEXT_PUBLIC_ADSTERRA_BROWSE_FEED_SRC=""
NEXT_PUBLIC_ADSTERRA_BROWSE_FEED_CONTAINER=""
